# Copy this file to /etc/clawhost/<instance-name>.env and fill in the real values.
# The matching systemd unit is:
#   examples/services/systemd/clawhost-instance-bootstrap@.service
#
# Example:
#   sudo install -d -m 0755 /etc/clawhost
#   sudo install -m 0640 examples/services/systemd/clawhost-instance.env.example /etc/clawhost/llm-report-module.env
#   sudoedit /etc/clawhost/llm-report-module.env
#   sudo cp examples/services/systemd/clawhost-instance-bootstrap@.service /etc/systemd/system/
#   sudo systemctl daemon-reload
#   sudo systemctl enable --now clawhost-instance-bootstrap@llm-report-module.service

# Path to this checked-out repo on the host.
CLAWHOST_REPO_ROOT=/opt/clawhost-kit

# Shared host runtime root created by scripts/bootstrap-host-runtime.sh install.
CLAWHOST_RUNTIME_ROOT=/srv/clawhost
CLAWHOST_INSTANCES_ROOT=/srv/clawhost/instances

# Per-instance configuration for scripts/clawhost-instance.py.
CLAWHOST_INSTANCE_NAME=llm-report-module
CLAWHOST_REPO_URL=https://github.com/sejeonglee/llm-report-module
CLAWHOST_DEFAULT_BRANCH=main
CLAWHOST_HOST_DEFAULTS_REF=clawhost-dev-01
CLAWHOST_POLL_INTERVAL_SECONDS=300
CLAWHOST_MAX_PARALLEL_TASKS=1
CLAWHOST_MAX_ACTIVE_WORKTREES=2

# Fill these with the real commands for your host when the tools are not already installed.
OPENCLAW_INSTALL_CMD=
CLAWTEAM_INSTALL_CMD=
